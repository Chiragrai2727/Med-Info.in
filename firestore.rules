rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'aethelcare.help@gmail.com'
      ); 
    }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'createdAt']) 
          && data.keys().size() <= 15
          && data.uid == request.auth.uid // Identity Integrity
          && data.email is string && data.email.size() <= 256
          && data.createdAt == request.time;
      }
      
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin(); 
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId 
        && isValidUser(incoming());
        
      allow update: if (isSignedIn() && request.auth.uid == userId && incoming().uid == existing().uid)
        || isAdmin();
        
      allow delete: if isAdmin(); 
    }

    // Schedules Collection 
    match /schedules/{scheduleId} {
      function isValidSchedule(data) {
        return data.keys().hasAll(['userId', 'medicineName', 'dosage', 'time', 'days', 'createdAt'])
          && data.keys().size() <= 8
          && data.userId == request.auth.uid
          && data.medicineName is string && data.medicineName.size() <= 100
          && data.dosage is string && data.dosage.size() <= 100
          && data.time is string && data.time.size() <= 10
          && data.days is list && data.days.size() <= 7 && data.days.size() > 0 && data.days[0] is string
          && data.createdAt == request.time;
      }
      
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(scheduleId) 
        && isValidSchedule(incoming());
        
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId 
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['medicineName', 'dosage', 'time', 'days']);
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Medicines Collection (Self-Building Cache)
    match /medicines/{medicineId} {
      function isValidMedicine(data) {
        return data.keys().hasAll(['id', 'drug_name', 'createdBy', 'createdAt'])
          && data.keys().size() <= 25
          && data.createdBy == request.auth.uid // Identity check
          && data.id is string && data.id.size() <= 128
          && data.drug_name is string && data.drug_name.size() <= 200
          && data.createdAt == request.time;
      }
      
      // Anyone can read the public dictionary
      allow read: if true; 
      
      // Users can append new medicines when AI generates them
      allow create: if isSignedIn() 
        && isValidId(medicineId) 
        && isValidMedicine(incoming());
        
      allow update: if false; 
      allow delete: if false;
    }
    
    match /searchAnalytics/{queryId} {
      allow read: if isAdmin(); 
      allow write: if isSignedIn(); // Allow users to contribute to analytics via search
      allow delete: if isAdmin();
    }
  }
}
