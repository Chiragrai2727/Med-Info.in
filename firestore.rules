rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "raisahab2727@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'isPremium', 'createdAt', 'role', 'subscriptionTier', 'subscriptionExpiry']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('subscriptionTier' in data) || data.subscriptionTier in ['none', 'daily', 'monthly', 'yearly']) &&
             (!('subscriptionExpiry' in data) || data.subscriptionExpiry is string) &&
             data.createdAt is string &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }
    
    function isValidSchedule(data) {
      return hasOnlyAllowedFields(['userId', 'medicineName', 'dosage', 'time', 'days', 'createdAt', 'lastTakenDate', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.medicineName is string && data.medicineName.size() > 0 && data.medicineName.size() < 200 &&
             data.dosage is string && data.dosage.size() > 0 && data.dosage.size() < 100 &&
             data.time is string && data.time.matches("^[0-9]{2}:[0-9]{2}$") &&
             data.days is list && data.days.size() > 0 && data.days.size() <= 7 &&
             data.createdAt is string;
    }
    
    function isValidSearchAnalytics(data) {
      return hasOnlyAllowedFields(['query', 'count', 'lastSearchedAt']) &&
             data.query is string && data.query.size() > 0 && data.query.size() < 200 &&
             data.count is number && data.count >= 0 &&
             data.lastSearchedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.get('role', 'user') == resource.data.get('role', 'user') || isAdmin());
      
      match /payments/{paymentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['amount', 'tier', 'date', 'status']) &&
                      request.resource.data.amount is number &&
                      request.resource.data.tier in ['daily', 'monthly', 'yearly'] &&
                      request.resource.data.date is string &&
                      request.resource.data.status is string;
        allow update: if isAdmin();
      }
    }

    match /schedules/{scheduleId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidSchedule(request.resource.data);
      allow update: if isDocOwner() && request.resource.data.userId == request.auth.uid && isValidSchedule(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /searchAnalytics/{queryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSearchAnalytics(request.resource.data);
      allow update: if isAuthenticated() && isValidSearchAnalytics(request.resource.data) && 
                    request.resource.data.query == resource.data.query &&
                    request.resource.data.count == resource.data.count + 1;
    }
  }
}
